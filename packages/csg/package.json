{
  "name": "@ifc-lite/csg",
  "version": "0.1.0",
  "description": "Constructive solid geometry (boolean subtraction) for IFC-Lite meshes",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch",
    "test": "node --test --import tsx 'src/**/*.test.ts'",
    "typecheck": "pnpm exec tsc --noEmit"
  },
  "dependencies": {
    "@ifc-lite/geometry": "workspace:^",
    "manifold-3d": "^3.2.1"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "license": "MPL-2.0",
  "author": "Louis True",
  "repository": {
    "type": "git",
    "url": "https://github.com/louistrue/ifc-lite.git",
    "directory": "packages/csg"
  },
  "homepage": "https://louistrue.github.io/ifc-lite/",
  "bugs": "https://github.com/louistrue/ifc-lite/issues",
  "keywords": [
    "ifc",
    "bim",
    "csg",
    "boolean",
    "manifold"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
