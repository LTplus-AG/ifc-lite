{
  "name": "@ifc-lite/wasm-threaded",
  "type": "module",
  "private": true,
  "collaborators": [
    "IFC-Lite Contributors"
  ],
  "description": "Thread-enabled WebAssembly bindings for IFC-Lite (uses wasm-bindgen-rayon for in-WASM parallelism). Requires cross-origin isolation (COOP/COEP). Generated by `THREADED=1 scripts/build-wasm.sh`.",
  "version": "0.1.0",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/louistrue/ifc-lite"
  },
  "files": [
    "pkg/ifc-lite_bg.wasm",
    "pkg/ifc-lite.js",
    "pkg/ifc-lite.d.ts",
    "pkg/snippets/**"
  ],
  "main": "./pkg/ifc-lite.js",
  "module": "./pkg/ifc-lite.js",
  "types": "./pkg/ifc-lite.d.ts",
  "exports": {
    ".": {
      "import": "./pkg/ifc-lite.js",
      "types": "./pkg/ifc-lite.d.ts"
    }
  },
  "sideEffects": [
    "./pkg/snippets/*"
  ]
}
